    <link rel="icon" type="image/png" href="favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #ffffff; --surface: #ffffff; --surface2: #f4f6f8;
            --accent: #00c86a; --accent-glow: rgba(0,200,106,0.25);
            --gold: #c5960f; --gold-glow: rgba(197,150,15,0.2);
            --text: #0d0f12; --text2: #5a6270;
            --border-c: rgba(13,15,18,0.08);
            --radius: 6px; --border: 1px solid var(--border-c);
            --font-mono: 'JetBrains Mono', 'Courier New', 'Fira Code', monospace;
            --shadow-sm: 0 1px 2px rgba(13,15,18,0.04), 0 2px 8px rgba(13,15,18,0.04);
            --shadow-md: 0 4px 12px rgba(13,15,18,0.06), 0 12px 32px rgba(13,15,18,0.06);
            --shadow-lg: 0 8px 24px rgba(13,15,18,0.08), 0 24px 64px rgba(13,15,18,0.08);
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        html { scroll-behavior:smooth; margin:0; padding:0; -webkit-overflow-scrolling:touch; }
        @media (max-width:850px) { html { scroll-behavior:auto; } }

        body {
            font-family:'Inter','Segoe UI',system-ui,-apple-system,BlinkMacSystemFont,sans-serif;
            background:var(--bg); color:var(--text);
            line-height:1.6; margin:0; padding:0;
            -webkit-overflow-scrolling: touch;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
            text-rendering: optimizeLegibility;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        /* Pause heavy/annoying animations when tab is in background */
        body.tab-hidden .bg-slow-scan,
        body.tab-hidden #codeRain,
        body.tab-hidden .orb,
        body.tab-hidden #parallaxGrid,
        body.tab-hidden .bg-datastream,
        body.tab-hidden .bg-datastream::before,
        body.tab-hidden .bg-datastream::after,
        body.tab-hidden .bg-hud-axis { animation-play-state: paused !important; }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.001ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.001ms !important;
            }
        }
        /* Matrix rain hidden on light theme */
        #codeRain { display:none; }

        .perspective-wrap {
            position: relative; z-index: 1;
            contain: layout style;
        }

        /* Clean light dot grid */
        .grid-bg {
            position:fixed; inset:0; pointer-events:none; z-index:0;
            background-image:radial-gradient(rgba(13,15,18,0.09) 1px, transparent 1px);
            background-size:28px 28px;
            background-position: -1px -1px;
            transition: transform 0.1s linear;
            transform: translate3d(0,0,0);
            will-change: transform;
            opacity:0.6;
        }

        /* Soft accent glows in the corners (subtle, for light theme) */
        .bg-vignette {
            position:fixed; inset:0; pointer-events:none; z-index:0;
            background:
              radial-gradient(ellipse at 12% 8%, rgba(0,200,106,0.10), transparent 45%),
              radial-gradient(ellipse at 92% 92%, rgba(197,150,15,0.09), transparent 50%);
        }
        /* Disable dark-theme CRT/scan/datastream/axis/noise overlays on light theme */
        .bg-noise, .bg-slow-scan, .bg-datastream, .bg-hud-axis, .scan-line { display:none !important; }

        /* Floating soft pastel glows */
        .orb {
            position: fixed; border-radius: 50%; pointer-events: none; z-index: 0;
            filter: blur(100px);
            animation: floatOrb 20s ease-in-out infinite;
            will-change: transform;
            transform: translateZ(0);
        }
        .orb-1 { width:420px; height:420px; background:var(--accent); top:-10%; left:-8%;  opacity:0.18; animation-delay:0s; }
        .orb-2 { width:300px; height:300px; background:var(--gold);   top:50%;   right:-8%; opacity:0.18; animation-delay:-6s; }
        .orb-3 { width:360px; height:360px; background:var(--accent); bottom:-10%; left:25%; opacity:0.12; animation-delay:-12s; }
        @keyframes floatOrb {
            0%,100% { transform: translate3d(0,0,0) scale(1); }
            50%     { transform: translate3d(25px,-20px,0) scale(1.06); }
        }

        /* Smoothness hints */
        .reveal, .reveal-left, .reveal-right, .reveal-scale, .project-card,
        .service-card, .expertise-card, .process-step, .highlight-item, .about-card,
        .btn, .nav-cta, .scroll-top-btn, .cursor-dot, .cursor-ring {
            will-change: transform, opacity;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
        }
        section { content-visibility: auto; contain-intrinsic-size: 1px 600px; }
        section#home, section#contact { content-visibility: visible; }

        /* ── Scroll Reveal ── */
        .reveal {
            opacity: 0;
            transform: translateY(60px) rotateX(4deg);
            transition: all 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0) rotateX(0);
        }
        .reveal-left {
            opacity: 0;
            transform: translateX(-60px) rotateY(8deg);
            transition: all 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
        }
        .reveal-left.visible {
            opacity: 1;
            transform: translateX(0) rotateY(0);
        }
        .reveal-right {
            opacity: 0;
            transform: translateX(60px) rotateY(-8deg);
            transition: all 0.9s cubic-bezier(0.22, 0.61, 0.36, 1);
        }
        .reveal-right.visible {
            opacity: 1;
            transform: translateX(0) rotateY(0);
        }
        .reveal-scale {
            opacity: 0;
            transform: scale(0.8);
            transition: all 0.8s cubic-bezier(0.22, 0.61, 0.36, 1);
        }
        .reveal-scale.visible {
            opacity: 1;
            transform: scale(1);
        }

        /* Stagger children */
        .reveal-stagger > * { opacity:0; transform:translateY(40px); transition:all 0.6s cubic-bezier(0.22,0.61,0.36,1); }
        .reveal-stagger.visible > *:nth-child(1) { transition-delay:0s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(2) { transition-delay:0.12s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(3) { transition-delay:0.24s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(4) { transition-delay:0.36s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(5) { transition-delay:0.48s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(6) { transition-delay:0.6s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(7) { transition-delay:0.72s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(8) { transition-delay:0.84s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(9) { transition-delay:0.96s; opacity:1; transform:translateY(0); }
        .reveal-stagger.visible > *:nth-child(10) { transition-delay:1.08s; opacity:1; transform:translateY(0); }

        nav { position:fixed; top:0; left:0; right:0; z-index:1000; background:rgba(255,255,255,0.85); backdrop-filter:blur(16px) saturate(180%); -webkit-backdrop-filter:blur(16px) saturate(180%); border-bottom:1px solid var(--border-c); padding:0 2rem; box-shadow:0 1px 0 rgba(13,15,18,0.04), 0 4px 20px rgba(13,15,18,0.04); }
        nav::after { content:''; position:absolute; bottom:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,var(--accent),transparent); opacity:0; transition:opacity 0.6s; }
        nav:hover::after { opacity:1; }
        .nav-inner { max-width:1200px; margin:0 auto; display:grid; grid-template-columns:180px 1fr auto; align-items:center; height:64px; }
        .nav-logo { display:flex; align-items:center; }
        .nav-logo img { height:36px; width:auto; filter:drop-shadow(0 0 8px rgba(0,255,136,0.5)); transition:transform 0.5s; }
        .nav-logo:hover img { transform: rotateY(360deg); transition:transform 1s; }
        .nav-links { display:flex; gap:2rem; list-style:none; align-items:center; justify-content:center; }
        .nav-links a { color:var(--text2); text-decoration:none; font-size:0.85rem; font-weight:500; font-family:var(--font-mono); letter-spacing:1px; transition:all 0.3s; text-transform:uppercase; display:inline-block; }
        .nav-links a:hover { color:var(--accent); }
        .nav-links .nav-cta-wrap { display:none; }
        
        .nav-cta { background:transparent; color:var(--accent); border:1px solid var(--accent); padding:0.3rem 0.8rem; border-radius:2px; font-weight:600; font-size:0.68rem; font-family:var(--font-mono); letter-spacing:1px; text-transform:uppercase; transition:all 0.25s; text-decoration:none; cursor:pointer; }
        .nav-cta-wrap { display:block; }
        .nav-cta:hover { background:var(--accent); color:#fff; box-shadow:0 6px 20px var(--accent-glow); }

        .hero { min-height:70vh; display:flex; align-items:center; justify-content:center; padding:5rem 2rem 0; position:relative; transform-style:preserve-3d; }
        .hero::before { display:none; }
        .hero::after { display:none; }
        .hero-content { max-width:800px; text-align:center; position:relative; z-index:1; }
        .hero-badge { display:none; }
        .hero h1 { font-size:clamp(2.8rem,7vw,5rem); font-weight:800; line-height:1.1; margin-bottom:1.5rem; letter-spacing:-1px; }
        .hero h1 .name { color:var(--accent); }
        .hero h1 .gold-dot { color:var(--gold); }
        .hero p.subtitle { font-size:1.15rem; color:var(--text2); font-family:inherit; letter-spacing:0; margin-bottom:2rem; font-weight:400; }
        .hero p.subtitle .cursor {
            display:inline-block; width:2px; height:1.1em;
            background:var(--accent);
            margin-left:4px; vertical-align:text-bottom;
            animation: cursorBlink 0.9s steps(2) infinite;
        }
        @keyframes cursorBlink {
            0%,100% { opacity:1; }
            50% { opacity:0; }
        }
        .hero-stats { display:flex; gap:2rem; justify-content:center; flex-wrap:wrap; margin:2rem 0; }
        .hero-stat { text-align:center; }
        .hero-stat .num { font-size:2.4rem; font-weight:800; font-family:var(--font-mono); color:var(--accent); }
        .hero-stat:nth-child(2) .num { color:var(--gold); }
        .hero-stat .label { font-size:0.88rem; color:var(--text2); font-family:var(--font-mono); letter-spacing:1px; }
        .hero-buttons { display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; }
        .btn, button.btn { padding:0.8rem 2rem; border-radius:2px; font-weight:600; font-size:0.85rem; text-decoration:none; display:inline-block; transition:all 0.25s; font-family:var(--font-mono); letter-spacing:2px; text-transform:uppercase; }
        .btn-primary { background:var(--accent); color:#fff; border:none; clip-path:polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%); }
        .btn-primary:hover { background:#00b55f; color:#fff; box-shadow:0 8px 24px var(--accent-glow); transform:translateY(-2px); }
        .btn-outline { background:transparent; color:var(--text); border:1px solid var(--border-c); clip-path:polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%); }
        .btn-outline:hover { border-color:var(--accent); color:var(--accent); background:rgba(0,200,106,0.05); transform:translateY(-2px); }

        section { padding:2rem 2rem 0; max-width:1200px; margin:0 auto; position:relative; z-index:1; scroll-margin-top:80px; transform-style:preserve-3d; }
        .section-title { font-size:2.6rem; font-weight:800; text-align:center; margin-bottom:0.2rem; font-family:var(--font-mono); letter-spacing:-1px; }
        .section-title .green { color:var(--accent); }
        .section-title .gold { color:var(--gold); }
        .section-subtitle { text-align:center; color:var(--text2); margin-bottom:2.5rem; font-size:1rem; font-family:inherit; letter-spacing:0; }
        .corner-deco { position:absolute; width:24px; height:24px; border-color:rgba(0,200,106,0.4); border-style:solid; pointer-events:none; transition:all 0.6s; }
        .corner-tl { top:0; left:0; border-width:2px 0 0 2px; }
        .corner-br { bottom:0; right:0; border-width:0 2px 2px 0; }

        .about-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; align-items:start; }
        .about-card { background:var(--surface); border-radius:var(--radius); padding:2rem; border:var(--border); position:relative; box-shadow:var(--shadow-sm); transition:all 0.4s; }
        .about-card:hover { transform:translateY(-4px); box-shadow:var(--shadow-md); border-color:rgba(0,200,106,0.3); }
        .about-card h3 { font-size:1.6rem; margin-bottom:0.8rem; color:var(--accent); font-family:var(--font-mono); letter-spacing:2px; }
        .about-card p { color:var(--text2); margin-bottom:0.8rem; font-size:1.05rem; line-height:1.6; }
        .about-highlights { display:grid; grid-template-columns:1fr 1fr; gap:1rem; padding:6px; margin:-6px; }
        .highlight-item { background:var(--surface); border-radius:var(--radius); padding:1.5rem; border:var(--border); text-align:center; transition:all 0.3s; }
        .highlight-item:hover { border-color:var(--accent); box-shadow:var(--shadow-md); transform:translateY(-4px); }
        .highlight-item .icon { display:flex; justify-content:center; margin-bottom:0.5rem; } .highlight-item .icon svg { color:var(--accent); }
        .highlight-item h4 { font-size:1.05rem; margin-bottom:0.3rem; font-family:var(--font-mono); letter-spacing:1px; }
        .highlight-item:nth-child(1) .icon svg { color: var(--accent); }
        .highlight-item:nth-child(2) .icon svg { color: var(--gold); }
        .highlight-item:nth-child(3) .icon svg { color: var(--accent); }
        .highlight-item:nth-child(4) .icon svg { color: var(--gold); }
        .highlight-item:nth-child(1) h4 { color:var(--accent); }
        .highlight-item:nth-child(2) h4 { color:var(--gold); }
        .highlight-item:nth-child(3) h4 { color:var(--accent); }
        .highlight-item:nth-child(4) h4 { color:var(--gold); }
        .highlight-item p { font-size:0.95rem; color:var(--text2); }

        /* ── Expertise Cards ── */
        .expertise-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:1.5rem; padding:6px; margin:-6px; }
        .expertise-card {
            background:var(--surface); border-radius:var(--radius); padding:2rem 1.5rem;
            border:var(--border); text-align:center; transition:all 0.3s;
            position:relative;
        }
        .expertise-card:hover {
            border-color:var(--accent); box-shadow:var(--shadow-md);
            transform:translateY(-6px);
        }
        .expertise-icon { transition:transform 0.4s; } .expertise-icon svg { color:var(--accent); }
        .expertise-card:hover .expertise-icon { transform:translateZ(20px); }
        .expertise-card h4 { font-size:1.2rem; margin-bottom:0.4rem; font-family:var(--font-mono); letter-spacing:0.5px; }
        .expertise-card:nth-child(1) h4 { color:var(--accent); }
        .expertise-card:nth-child(2) h4 { color:var(--gold); }
        .expertise-card:nth-child(3) h4 { color:var(--accent); }
        .expertise-card p { font-size:1rem; color:var(--text2); line-height:1.6; }
        .expertise-tags { display:flex; flex-wrap:wrap; gap:0.4rem; justify-content:center; margin-top:0.8rem; }
        .expertise-tags span {
            font-family:var(--font-mono); font-size:0.62rem; letter-spacing:1px;
            color:var(--text2); background:var(--surface2); border:1px solid var(--border-c);
            padding:0.2rem 0.6rem; border-radius:100px; transition:all 0.2s;
        }
        .expertise-card:hover .expertise-tags span {
            border-color:var(--accent); color:var(--accent); background:rgba(0,200,106,0.06);
        }

        .services-grid { display:grid; grid-template-columns:repeat(4, 1fr); gap:1.2rem; padding:8px; margin:-8px; }
        .service-card { background:var(--surface); border-radius:var(--radius); padding:2rem 1.2rem; border:var(--border); text-align:center; transition:all 0.3s; position:relative; }
        .service-card:hover { border-color:var(--accent); box-shadow:var(--shadow-md); transform:translateY(-6px); }
        .service-icon { transition:transform 0.4s; } .service-icon svg { color:var(--accent); }
        .service-card:hover .service-icon { transform:translateZ(20px); }
        .service-card h4 { font-size:1.15rem; margin-bottom:0.5rem; font-family:var(--font-mono); letter-spacing:0.5px; }
        .service-card p { font-size:1rem; color:var(--text2); }

        .process-timeline { display:grid; grid-template-columns:repeat(4, 1fr); gap:1.2rem; padding:6px; margin:-6px; }
        .process-step { background:var(--surface); border-radius:var(--radius); padding:2rem 1.2rem; border:var(--border); text-align:center; transition:all 0.3s; }
        .process-step:hover { border-color:var(--gold); box-shadow:var(--shadow-md); transform:translateY(-4px); }
        .process-num { width:48px; height:48px; background:var(--surface2); border:2px solid var(--accent); border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:1.1rem; margin:0 auto 1rem; font-family:var(--font-mono); color:var(--accent); transition:all 0.3s; }
        .process-step:hover .process-num { transform:scale(1.08); box-shadow:var(--shadow-sm); }
        .process-step:nth-child(even) .process-num { border-color:var(--gold); color:var(--gold); }
        .process-step h4 { font-size:1.1rem; margin-bottom:0.5rem; font-family:var(--font-mono); letter-spacing:0.5px; }
        .process-step p { font-size:1rem; color:var(--text2); }

        .projects-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:1.5rem; padding:8px; margin:-8px; }
        a.project-card { text-decoration:none; color:inherit; display:block; }
        .project-card {
            background:var(--surface); border-radius:var(--radius); border:var(--border);
            transition:transform 0.3s cubic-bezier(0.22,0.61,0.36,1), border-color 0.3s, box-shadow 0.3s;
            cursor:pointer; margin:4px; position:relative; overflow:hidden;
            backface-visibility:hidden; -webkit-backface-visibility:hidden;
            box-shadow:var(--shadow-sm);
        }
        /* No pseudo-element glow on the whole card — RGB glow lives on the image only */
        .project-card::before, .project-card::after { display:none !important; }
        .project-card:hover {
            transform: translateY(-6px);
            border-color:rgba(0,200,106,0.4);
            box-shadow:var(--shadow-lg);
        }
        .project-image {
            height:200px; position:relative; overflow:hidden;
            border-radius:var(--radius) var(--radius) 0 0;
            border-bottom:1px solid var(--border-c);
            background-size:cover; background-position:center top; background-repeat:no-repeat;
            transition:transform 0.4s cubic-bezier(0.22,0.61,0.36,1), filter 0.4s, box-shadow 0.4s;
        }
        /* RGB glow is confined to the thumbnail image — never bleeds onto text */
        .project-card:hover .project-image {
            transform:scale(1.02);
        }
        .project-image::before { content:''; position:absolute; inset:0; background:rgba(0,0,0,0.2); z-index:1; transition:background 0.3s; }
        .project-card:hover .project-image::before { background:rgba(0,0,0,0.5); }
        .project-image::after { display:none; }
        .project-image .hover-hint { position:absolute; inset:0; background:rgba(255,255,255,0.92); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:0.6rem; opacity:0; transition:opacity 0.3s; z-index:5; font-family:var(--font-mono); color:var(--accent); letter-spacing:2px; }
        .project-card:hover .hover-hint { opacity:1; }
        .hover-hint .visit-btn { display:inline-block; padding:0.6rem 1.4rem; border:none; color:#fff; background:var(--accent); font-family:var(--font-mono); font-size:0.8rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; border-radius:6px; transition:all 0.25s; }
        .hover-hint .visit-btn:hover { background:#00b55f; color:#fff; transform:scale(1.05); }
        
        @keyframes _rgbText {
            0%   { color:#ff3377; border-color:#ff3377; }
            33%  { color:#00ff88; border-color:#00ff88; }
            66%  { color:#33bbff; border-color:#33bbff; }
            100% { color:#ff3377; border-color:#ff3377; }
        }
        .hover-hint .visit-arrow { font-size:0.65rem; color:rgba(255,255,255,0.8); letter-spacing:2px; animation: arrowBlink 1s steps(2) infinite; }
        @keyframes _rgbBtnPulse {
            0%,100% { box-shadow:0 0 20px rgba(255,0,80,0.25),0 0 20px rgba(0,255,136,0.25),0 0 20px rgba(0,170,255,0.25),inset 0 0 20px rgba(0,255,136,0.08); border-color:var(--accent); }
            33%     { box-shadow:0 0 35px rgba(255,0,80,0.6), 0 0 30px rgba(0,255,136,0.3), 0 0 20px rgba(0,170,255,0.2), inset 0 0 22px rgba(255,0,80,0.15);  border-color:#ff4488; }
            66%     { box-shadow:0 0 20px rgba(255,0,80,0.2), 0 0 30px rgba(0,255,136,0.3), 0 0 35px rgba(0,170,255,0.6), inset 0 0 22px rgba(0,170,255,0.15); border-color:#44ccff; }
        }
        
        .project-info { padding:1.3rem; background:var(--surface); }
        .project-info h4 { font-size:1.15rem; margin-bottom:0.2rem; font-family:var(--font-mono); letter-spacing:0; font-weight:600; color:var(--text); transition:color 0.3s; }
        .project-info .domain { font-size:0.82rem; color:var(--accent); margin-bottom:0.5rem; font-family:var(--font-mono); transition:color 0.3s; }
        .project-info p { font-size:0.95rem; color:var(--text2); transition:color 0.3s; line-height:1.55; }
        .project-card:hover .project-info h4 { color:var(--text); }
        .project-card:hover .project-info .domain { color:var(--accent); }
        .project-card:hover .project-info p { color:var(--text); }

        /* ── RGB CHROMATIC-ABERRATION GLITCH for Recent Projects title ── */
        #projects .section-title-wrap { text-align:center; margin-bottom:0.2rem; position:relative; perspective:800px; }
        .glitch { position:relative; display:block; text-align:center; font-size:2.4rem; font-weight:800; font-family:var(--font-mono); letter-spacing:-1px; color:var(--text); margin:0; isolation:isolate; }
        /* Three stacked clones for R / G / B channel separation — sit ABOVE the text so offsets are always visible */
        .glitch .r, .glitch .g, .glitch .b {
            position:absolute; top:0; left:0; width:100%; height:100%;
            pointer-events:none; mix-blend-mode:screen;
            text-align:center;
        }
        .glitch .r { color:var(--accent); z-index:1; opacity:0.4; animation: none; }
        .glitch .g { color:var(--accent); z-index:1; opacity:0; }
        .glitch .b { color:var(--gold); z-index:1; opacity:0.3; animation: none; }
        .glitch .r .green, .glitch .r .gold { color:#ff0055 !important; text-shadow:inherit !important; }
        .glitch .g .green, .glitch .g .gold { color:#00ff88 !important; text-shadow:inherit !important; }
        .glitch .b .green, .glitch .b .gold { color:#00aaff !important; text-shadow:inherit !important; }
        .glitch:hover .r, .glitch:hover .g, .glitch:hover .b { animation-duration:0.18s; }

        /* ── Subtle/darker glitch variant for other section headers ── */
        .glitch-subtle { position:relative; display:block; text-align:center; margin:0 0 0.2rem; font-size:2.4rem; font-weight:800; font-family:var(--font-mono); letter-spacing:-1px; color:var(--text); isolation:isolate; }
        .glitch-subtle .r, .glitch-subtle .g, .glitch-subtle .b {
            position:absolute; top:0; left:0; width:100%; height:100%;
            pointer-events:none; mix-blend-mode:screen; opacity:0.7;
            text-align:center; z-index:1;
        }
        .glitch-subtle .r { display:none; }
        .glitch-subtle .g { display:none; }
        .glitch-subtle .b { display:none; }
        .glitch-subtle .r .green, .glitch-subtle .r .gold,
        .glitch-subtle .g .green, .glitch-subtle .g .gold,
        .glitch-subtle .b .green, .glitch-subtle .b .gold { color:inherit !important; text-shadow:inherit !important; }
        .glitch-subtle .r .green { color:#ff3377 !important; }
        .glitch-subtle .g .green { color:#00cc77 !important; }
        .glitch-subtle .b .green { color:#3399dd !important; }
        .glitch-subtle:hover .r, .glitch-subtle:hover .g, .glitch-subtle:hover .b { opacity:0.95; animation-duration:0.45s; }

        /* Subtle variant: RGB split is ALWAYS visible via base transform; keyframes add burst offsets. */
        @keyframes glitchRsub {
            0%,70%,100% { transform:translate(-1px,0);   clip-path:inset(0 0 0 0); }
            72%         { transform:translate(-4px,-1px); clip-path:inset(12% 0 55% 0); }
            74%         { transform:translate(3px,1px);   clip-path:inset(55% 0 15% 0); }
            76%         { transform:translate(-2px,0);    clip-path:inset(30% 0 40% 0); }
            82%         { transform:translate(-1px,0);    clip-path:inset(0 0 0 0); }
            88%         { transform:translate(2px,1px);   clip-path:inset(70% 0 5% 0);  }
        }
        @keyframes glitchGsub {
            0%,68%,100% { transform:translate(1px,0);    clip-path:inset(0 0 0 0); }
            70%         { transform:translate(4px,0);    clip-path:inset(60% 0 20% 0); }
            73%         { transform:translate(-3px,-1px);clip-path:inset(8% 0 65% 0);  }
            75%         { transform:translate(2px,1px);  clip-path:inset(38% 0 38% 0); }
            80%         { transform:translate(1px,0);    clip-path:inset(0 0 0 0); }
            90%         { transform:translate(-2px,-1px);clip-path:inset(20% 0 65% 0); }
        }
        @keyframes glitchBsub {
            0%,72%,100% { transform:translate(0,-1px);   clip-path:inset(0 0 0 0); }
            73%         { transform:translate(3px,-2px); clip-path:inset(28% 0 48% 0); }
            76%         { transform:translate(-3px,1px); clip-path:inset(62% 0 12% 0); }
            83%         { transform:translate(0,-1px);   clip-path:inset(0 0 0 0); }
            86%         { transform:translate(2px,2px);  clip-path:inset(45% 0 30% 0); }
        }

        /* Main glitch: constant chromatic offset + more frequent bursts */
        @keyframes glitchR {
            0%,60%,100% { transform:translate(-2px,0);   clip-path:inset(0 0 0 0); opacity:0.9; }
            62%         { transform:translate(-5px,-2px);clip-path:inset(8% 0 60% 0);  opacity:1; }
            64%         { transform:translate(4px,1px);  clip-path:inset(35% 0 25% 0); opacity:1; }
            67%         { transform:translate(-3px,2px); clip-path:inset(60% 0 8% 0);  opacity:1; }
            72%         { transform:translate(5px,-1px); clip-path:inset(20% 0 45% 0); opacity:1; }
            75%         { transform:translate(-2px,0);   clip-path:inset(0 0 0 0);    opacity:0.9; }
            85%         { transform:translate(2px,1px);  clip-path:inset(75% 0 8% 0);  opacity:1; }
        }
        @keyframes glitchG {
            0%,58%,100% { transform:translate(2px,0);    clip-path:inset(0 0 0 0); opacity:0.9; }
            60%         { transform:translate(5px,0);    clip-path:inset(55% 0 12% 0); opacity:1; }
            63%         { transform:translate(-4px,-1px);clip-path:inset(5% 0 70% 0);  opacity:1; }
            66%         { transform:translate(3px,2px);  clip-path:inset(30% 0 35% 0); opacity:1; }
            70%         { transform:translate(-5px,1px); clip-path:inset(70% 0 5% 0);  opacity:1; }
            73%         { transform:translate(2px,0);    clip-path:inset(0 0 0 0);    opacity:0.9; }
            88%         { transform:translate(-3px,-1px);clip-path:inset(15% 0 60% 0); opacity:1; }
        }
        @keyframes glitchB {
            0%,62%,100% { transform:translate(0,-1px);   clip-path:inset(0 0 0 0); opacity:0.8; }
            63%         { transform:translate(3px,-3px); clip-path:inset(22% 0 50% 0); opacity:1; }
            66%         { transform:translate(-3px,2px); clip-path:inset(65% 0 8% 0);  opacity:1; }
            71%         { transform:translate(4px,2px);  clip-path:inset(10% 0 60% 0); opacity:1; }
            74%         { transform:translate(0,-1px);   clip-path:inset(0 0 0 0);    opacity:0.8; }
            82%         { transform:translate(-2px,-2px);clip-path:inset(40% 0 40% 0); opacity:1; }
        }
        .glitch .tear { display:none !important; }

        .glitch-tag { display:inline-block; font-family:var(--font-mono); font-size:0.72rem; letter-spacing:2px; color:var(--accent); padding:0.35rem 1rem; border:1px solid rgba(0,200,106,0.25); border-radius:100px; margin-bottom:1.2rem; background:rgba(0,200,106,0.06); position:relative; overflow:hidden; }
        .glitch-tag::before { content:''; position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg, transparent, rgba(0,200,106,0.25), transparent); animation: tagShine 4s linear infinite; }
        @keyframes tagShine { to { left:100%; } }

        /* ── CLEAN ICON STYLES (light theme) ── */
        .highlight-item .icon,
        .service-icon,
        .expertise-icon {
            position:relative; display:inline-flex; align-items:center; justify-content:center;
            margin:0 auto; border-radius:14px;
            background:var(--surface2);
            transition: all 0.3s ease;
        }
        .highlight-item .icon { width:52px; height:52px; margin-bottom:0.8rem; border-radius:12px; }
        .service-icon, .expertise-icon { width:64px; height:64px; margin-bottom:1.2rem; border-radius:16px; }

        /* Soft colored border ring */
        .highlight-item .icon::before,
        .service-icon::before,
        .expertise-icon::before {
            content:''; position:absolute; inset:-2px; border-radius:inherit;
            border:2px solid transparent;
            background:linear-gradient(135deg, rgba(0,200,106,0.25), rgba(0,200,106,0)) border-box;
            -webkit-mask:linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor; mask-composite: exclude;
            opacity:0; transition: opacity 0.3s;
            pointer-events:none;
        }
        .highlight-item:nth-child(even) .icon::before,
        .expertise-card:nth-child(2) .expertise-icon::before {
            background:linear-gradient(135deg, rgba(197,150,15,0.3), rgba(197,150,15,0)) border-box;
        }
        .highlight-item:hover .icon::before,
        .service-card:hover .service-icon::before,
        .expertise-card:hover .expertise-icon::before { opacity:1; }

        /* Remove orbit dot on light theme */
        .highlight-item .icon::after,
        .service-icon::after,
        .expertise-icon::after { display:none !important; }

        /* SVG clean icon styling */
        .highlight-item .icon svg,
        .service-icon svg,
        .expertise-icon svg {
            position:relative; z-index:2;
            color:var(--accent);
            transition: transform 0.3s cubic-bezier(0.22,0.61,0.36,1);
        }

        /* Hover: lift and subtle scale */
        .highlight-item:hover .icon svg,
        .service-card:hover .service-icon svg,
        .expertise-card:hover .expertise-icon svg {
            transform:scale(1.1);
            color:var(--accent);
        }
        .highlight-item:hover .icon { transform:translateY(-2px); }
        .service-card:hover .service-icon { transform:translateY(-2px); background:rgba(0,200,106,0.08); }
        .expertise-card:hover .expertise-icon { transform:translateY(-2px); background:rgba(0,200,106,0.08); }

        /* Process step numbers — clean solid */
        .process-num { position:relative; overflow:visible; }
        .process-num::before { display:none; }
        .process-num::after { display:none; }

        /* Scroll-to-top and logo: no heavy pulse */
        .scroll-top-btn svg { animation: none; }
        .nav-logo img { animation: none; transition: transform 0.5s; }
        .nav-logo img:hover { filter: none; }

        /* Form success icon */
        .success-icon svg {
            color:var(--accent);
            animation: successPop 0.5s cubic-bezier(0.34,1.56,0.64,1);
        }
                @keyframes successPop {
            0%   { transform:scale(0) rotate(-180deg); opacity:0; }
            100% { transform:scale(1) rotate(0); opacity:1; }
        }
        /* Subtle RGB grid corner decorators on projects */
        #projects .corner-deco { border-color:rgba(0,200,106,0.3); }
        #projects .corner-deco:nth-child(2) { border-color:rgba(197,150,15,0.3); }

        .contact-section { background:var(--surface); border-radius:16px; padding:3.5rem 2.5rem; text-align:center; border:var(--border); margin:0 auto 5rem; max-width:900px; position:relative; z-index:2; box-shadow:var(--shadow-md); transition:transform 0.3s, box-shadow 0.3s; }
        .contact-section:hover { transform:translateY(-4px); border-color:rgba(0,200,106,0.4); box-shadow:var(--shadow-lg); }
        .contact-section h2 { font-size:2rem; margin-bottom:1rem; font-family:var(--font-mono); letter-spacing:1px; }
        .contact-section h2 .green { color:var(--accent); }
        .contact-section .lead { color:var(--text2); max-width:600px; margin:0 auto 1.8rem; font-size:1.1rem; line-height:1.7; }
        /* Ensure CTA button sits above everything in the contact card */
        .contact-section .btn-primary { position:relative; z-index:5; display:inline-block; margin:0.4rem auto 1.8rem; font-size:1rem !important; padding:1rem 2.5rem !important; cursor:pointer; }
        .contact-section .btn-primary:hover { transform:translateY(-2px); }
        .contact-benefits { display:flex; flex-wrap:wrap; gap:1rem; justify-content:center; margin-bottom:1.5rem; }
        .benefit-item { display:flex; align-items:center; gap:0.5rem; color:var(--text2); font-size:0.9rem; padding:0.45rem 0.9rem; border:var(--border); border-radius:100px; transition:all 0.25s; background:var(--surface); }
        .benefit-item:hover { border-color:var(--accent); color:var(--accent); transform:translateY(-2px); box-shadow:var(--shadow-sm); background:rgba(0,200,106,0.04); }
        .benefit-item .check { color:var(--accent); font-weight:bold; font-size:0.85rem; }
        .contact-info-row { display:flex; gap:2rem; justify-content:center; flex-wrap:wrap; margin-top:2rem; padding-top:2rem; border-top:1px solid var(--border-c); }
        .contact-item { color:var(--text2); font-size:1rem; display:flex; align-items:center; gap:0.5rem; font-family:var(--font-mono); transition:all 0.2s; }
        .contact-item:hover { color:var(--accent); }
        .contact-item .icon-text { font-size:1.1rem; }

        footer { text-align:center; padding:2rem; margin:0; color:var(--text2); font-size:0.85rem; border-top:1px solid var(--border-c); font-family:var(--font-mono); letter-spacing:1px; }
        footer p { margin:0; padding:0; line-height:1; }

        /* ── 3D Edge Glow on border ── */
        @keyframes borderPulse {
            0%,100% { border-color: var(--border-c); box-shadow: var(--shadow-sm); }
            50% { border-color: rgba(0,200,106,0.3); box-shadow: var(--shadow-md); }
        }
        .about-card, .contact-section {
            animation: borderPulse 4s ease-in-out infinite;
        }

        /* ── CONTACT FORM MODAL (kept) ── */
        @keyframes rippleOut {
            0% { width:0; height:0; opacity:0.8; }
            100% { width:120px; height:120px; opacity:0; }
        }
        @keyframes pulse { 0%,100% { opacity:0.25; } 50% { opacity:1; } }

        /* ── CONTACT FORM MODAL ── */
        .form-modal-overlay {
            position:fixed; inset:0; z-index:10001; background:rgba(13,15,18,0.5);
            backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); touch-action:none;
            display:flex; align-items:center; justify-content:center;
            opacity:0; pointer-events:none; transition:opacity 0.35s;
        }
        .form-modal-overlay.active { opacity:1; pointer-events:auto; }
        .form-modal {
            background:#fff; border:var(--border);
            border-radius:16px; padding:2.5rem; width:90vw; max-width:480px;
            max-height:90vh; overflow-y:auto; -webkit-overflow-scrolling:touch;
            position:relative; box-shadow:var(--shadow-lg);
            transform:translateY(20px) scale(0.97); transition:transform 0.3s cubic-bezier(0.22,0.61,0.36,1);
            margin:auto; -webkit-overflow-scrolling:touch;
        }
        .form-modal-overlay.active .form-modal { transform:translateY(0) scale(1); }
        .form-modal .form-close {
            position:absolute; top:1rem; right:1rem;
            background:var(--surface2); color:var(--text2); border:var(--border);
            width:32px; height:32px; display:flex; align-items:center; justify-content:center;
            cursor:pointer; font-size:0.9rem; font-family:var(--font-mono);
            transition:all 0.25s; border-radius:2px;
        }
        .form-modal .form-close:hover { background:var(--text); color:#fff; border-color:var(--text); }
        .form-modal h3 {
            font-family:var(--font-mono); color:var(--text);
            font-size:1.3rem; letter-spacing:0; margin-bottom:0.3rem; font-weight:700;
        }
        .form-modal .form-sub {
            font-family:var(--font-mono); color:var(--text2);
            font-size:0.75rem; letter-spacing:1px; margin-bottom:1.8rem;
        }
        .form-modal .form-group { margin-bottom:1.2rem; }
        .form-modal label {
            display:block; color:var(--text2);
            font-size:0.8rem; letter-spacing:0; margin-bottom:0.4rem; font-weight:500;
        }
        .form-modal input, .form-modal textarea, .form-modal select {
            width:100%; background:var(--surface2); color:var(--text);
            border:var(--border); border-radius:8px;
            padding:0.8rem 1rem; font-family:inherit; font-size:0.95rem;
            outline:none; transition:all 0.2s;
        }
        .form-modal input:focus, .form-modal textarea:focus, .form-modal select:focus {
            border-color:var(--accent); box-shadow:0 0 0 3px rgba(0,200,106,0.12);
        }
        .form-modal textarea { resize:vertical; min-height:90px; }
        .form-modal .form-submit {
            width:100%; background:var(--accent); color:#fff; border:none;
            padding:0.9rem; cursor:pointer; font-family:inherit;
            font-size:0.95rem; font-weight:600; letter-spacing:0;
            border-radius:8px;
            transition:all 0.3s; margin-top:0.5rem;
        }
        .form-modal .form-submit:hover {
            box-shadow:0 8px 20px var(--accent-glow);
            background:#00b55f;
            transform:translateY(-1px);
        }
        .form-modal .form-submit:disabled { opacity:0.5; cursor:not-allowed; }
        .form-success {
            display:none; text-align:center; padding:2rem 0;
        }
        .form-success .success-icon { font-size:3rem; margin-bottom:1rem; }
        .form-success h3 { margin-bottom:0.5rem; color:var(--accent); }
        .form-success p { color:var(--text2); font-size:0.9rem; }

        /* ── Custom Cursor (desktop only) ── */
        @media (pointer: fine) { html { cursor: auto; } }
        .cursor-dot, .cursor-ring { display:none !important; }
        .form-modal input, .form-modal textarea, .form-modal select, .form-modal .form-submit, .form-modal .form-close {
            cursor: auto;
        }
        body.no-scroll { overflow:hidden; }
        .cursor-dot {
            position: fixed; top:0; left:0; z-index: 99999; pointer-events: none;
            width: 8px; height: 8px; margin:0;
            background: var(--accent);
            border-radius: 50%;
            box-shadow: 0 0 12px var(--accent-glow), 0 0 24px var(--accent-glow);
            transition: width 0.2s ease-out, height 0.2s ease-out, background 0.2s, box-shadow 0.2s;
            transform: translate3d(0,0,0);
            will-change: transform;
            contain: layout paint size style;
        }
        .cursor-ring {
            position: fixed; top:0; left:0; z-index: 99998; pointer-events: none;
            width: 36px; height: 36px; margin:0;
            border: 1.5px solid rgba(0,255,136,0.5);
            border-radius: 50%;
            box-shadow: 0 0 8px rgba(0,255,136,0.15);
            transition: width 0.25s cubic-bezier(0.22,0.61,0.36,1),
                        height 0.25s cubic-bezier(0.22,0.61,0.36,1),
                        border-color 0.25s, background 0.25s;
            transform: translate3d(0,0,0);
            will-change: transform;
            contain: layout paint size style;
        }
        .cursor-ring.hovering {
            width: 48px; height: 48px;
            border-color: var(--gold);
            background: rgba(212,160,23,0.06);
            box-shadow: 0 0 16px var(--gold-glow);
        }
        .cursor-dot.hovering {
            width:12px; height:12px;
            background: var(--gold);
            box-shadow: 0 0 18px var(--gold-glow), 0 0 28px var(--gold-glow);
        }
        /* ── MOBILE OPTIMIZATION ── */
        @media (pointer: coarse) {
            body { cursor: auto; }
            .cursor-dot, .cursor-ring { display: none; }
        }
        button { cursor: pointer; }

        /* Hamburger menu */
        .hamburger {
            display:none; flex-direction:column; gap:5px; cursor:pointer;
            z-index:1001; background:none; border:none; padding:4px;
        }
        .hamburger span {
            display:block; width:24px; height:2px; background:var(--accent);
            transition:all 0.3s; border-radius:1px;
        }
        .hamburger.open span:nth-child(1) { transform:rotate(45deg) translate(5px,5px); }
        .hamburger.open span:nth-child(2) { opacity:0; }
        .hamburger.open span:nth-child(3) { transform:rotate(-45deg) translate(5px,-5px); }

        /* ── Scroll-to-Top Button ── */
        .scroll-top-btn {
            position: fixed; right: 1.5rem; bottom: 1.5rem;
            z-index: 9999; width: 44px; height: 44px;
            background:#fff; border:var(--border);
            border-radius: 50%; display: flex; align-items: center;
            justify-content: center; cursor: pointer;
            opacity: 0; visibility: hidden;
            transform: translateY(20px);
            transition: all 0.35s cubic-bezier(0.22,0.61,0.36,1);
            box-shadow: 0 0 20px rgba(0,255,136,0.1);
            pointer-events: none;
        }
        .scroll-top-btn.visible {
            opacity: 1; visibility: visible;
            transform: translateY(0);
            pointer-events: auto;
        }
        .scroll-top-btn:hover {
            background: var(--accent); border-color: var(--accent);
            box-shadow: 0 8px 20px var(--accent-glow);
        }
        .scroll-top-btn svg {
            width: 18px; height: 18px;
            stroke: var(--text2); fill: none;
            stroke-width: 2;
            transition: stroke 0.25s;
        }
        .scroll-top-btn:hover svg {
            stroke: #fff;
        }
        @media (max-width: 850px) {
            .scroll-top-btn { right: 1rem; bottom: 1rem; width: 40px; height: 40px; }
            .scroll-top-btn svg { width: 16px; height: 16px; }
        }


        @media (max-width:850px) {
            /* Nav hamburger */
            /* Mobile nav */
            .nav-inner { height:56px; padding:0 0.5rem; display:flex !important; justify-content:space-between; align-items:center; position:relative; }
            .nav-logo { position:absolute; left:50%; transform:translateX(-50%); }
            .nav-logo img { height:28px; }
            .hamburger { display:flex; }
            .nav-inner > .nav-cta-wrap { display:none !important; }
            .nav-links {
                display:flex !important; flex-direction:column; gap:0;
                position:fixed; top:56px; left:0; right:0;
                background:rgba(255,255,255,0.98); backdrop-filter:blur(16px);
                border-bottom:1px solid var(--border-c);
                box-shadow:0 8px 30px rgba(13,15,18,0.08);
                padding:0; max-height:0; overflow:hidden;
                transition:max-height 0.35s ease, padding 0.35s ease;
                grid-column:auto;
            }
            .nav-links.open { max-height:460px; padding:0.5rem 0; }
            .nav-links li { padding:0; }
            .nav-links a {
                display:block; padding:0.9rem 2rem; font-size:0.95rem;
                border-bottom:1px solid var(--border-c);
            }
            .nav-links .nav-cta-wrap { display:block !important; text-align:center; padding:0.8rem 2rem 1rem; }
            .nav-links .nav-cta { padding:0.5rem 1.8rem; font-size:0.78rem; }
            #desktopCta { display:none !important; }

            /* Hero */
            .hero { min-height:55vh; padding:5rem 1rem 1rem; }
            .hero h1 { font-size:2.3rem; }
            .hero p.subtitle { font-size:1.05rem; }
            .hero-stats { gap:1rem; }
            .hero-stat .num { font-size:1.8rem; }
            .hero-stat .label { font-size:0.78rem; }
            .btn, button.btn, .nav-cta { padding:0.65rem 1.5rem; font-size:0.85rem; letter-spacing:1px; }
            .hero-buttons { flex-direction:column; align-items:center; }

            /* Sections */
            section { padding:1.5rem 1rem 0; }
            .section-title, .glitch-subtle, .glitch { font-size:1.8rem !important; }
            .section-subtitle { font-size:0.88rem; margin-bottom:1rem; }

            /* All grids → single column */
            .about-grid, .services-grid, .expertise-grid, .projects-grid,
            .process-timeline, .about-highlights {
                grid-template-columns:1fr; gap:0.8rem; padding:4px; margin:-4px;
            }

            /* Glitch title */
            .glitch { font-size:1.8rem !important; }
            .glitch .r { text-shadow:2px 0 6px rgba(255,0,85,0.7), 0 0 10px rgba(255,0,85,0.5); opacity:0.85; }
            .glitch .g { text-shadow:-2px 0 6px rgba(0,255,136,0.65), 0 0 10px rgba(0,255,136,0.45); opacity:0.85; }
            .glitch .b { text-shadow:0 0 8px rgba(0,170,255,0.6), 2px 0 4px rgba(0,170,255,0.5); opacity:0.75; }
            .glitch-subtle .r { text-shadow:1px 0 3px rgba(255,51,119,0.6), 0 0 8px rgba(255,51,119,0.4); opacity:0.65; }
            .glitch-subtle .g { text-shadow:-1px 0 3px rgba(0,204,119,0.55), 0 0 8px rgba(0,204,119,0.35); opacity:0.65; }
            .glitch-subtle .b { text-shadow:0 0 6px rgba(51,153,221,0.4), 1px 0 3px rgba(51,153,221,0.45); opacity:0.6; }
            .glitch-tag { font-size:0.6rem; letter-spacing:3px; }
            .project-card { margin:2px; }
            /* Cards */
            .about-card { padding:1.3rem; }
            .about-card h3 { font-size:1.25rem; }
            .about-card p { font-size:0.92rem; }
            .expertise-card, .service-card, .process-step, .highlight-item { padding:1.4rem 1rem; }
            .highlight-item .icon, .service-icon, .expertise-icon { width:44px !important; height:44px !important; margin-bottom:0.6rem !important; }
            .service-icon, .expertise-icon { width:48px !important; height:48px !important; margin-bottom:0.8rem !important; }
            .highlight-item .icon::before, .service-icon::before, .expertise-icon::before { display:none; }
            .highlight-item .icon::after,  .service-icon::after,  .expertise-icon::after  { display:none; }
            .process-num::before, .process-num::after { display:none; }
            .expertise-icon svg, .service-icon svg { width:32px; height:32px; } .highlight-item .icon svg { width:28px; height:28px; }
            .expertise-card h4, .service-card h4 { font-size:1.05rem; }
            .expertise-card p, .service-card p { font-size:0.88rem; }
            .expertise-tags span { font-size:0.58rem; padding:0.15rem 0.4rem; }
            .project-image { height:150px; }
            .project-card:hover .project-image { box-shadow: 0 0 0 1px rgba(0,255,136,0.3), 0 0 22px rgba(0,255,136,0.3), -4px 0 0 rgba(255,0,80,0.3), 4px 0 0 rgba(0,170,255,0.3); }
            .hover-hint .visit-btn { padding:0.45rem 1rem; font-size:0.75rem; letter-spacing:2px; }
            .hover-hint .visit-arrow { font-size:0.6rem; letter-spacing:3px; }
            .project-info { padding:0.9rem; }
            .project-info h4 { font-size:1rem; }
            .project-info p { font-size:0.88rem; }
            .project-info .domain { font-size:0.78rem; }

            /* Process */
            .process-num { width:40px; height:40px; font-size:1rem; }
            .process-step h4 { font-size:1rem; }
            .process-step p { font-size:0.85rem; }

            /* Contact */
            .contact-section { padding:1.5rem 1rem; margin:0 auto 2.5rem; }
            .contact-section h2.glitch-subtle { font-size:1.6rem !important; }
            .contact-section .lead { font-size:0.92rem; margin-bottom:1rem; }
            .contact-benefits { gap:0.5rem; margin-bottom:1rem; }
            .benefit-item { font-size:0.82rem; padding:0.25rem 0.6rem; }
            .contact-info-row { gap:0.8rem; margin-top:1rem; padding-top:1rem; }
            .contact-item { font-size:0.85rem; }

            /* Footer */
            footer { padding:1rem; font-size:0.68rem; }

            /* Modal devices */


            /* Form modal */
            .form-modal { padding:1.3rem; width:94vw; max-height:82vh; overflow-y:auto; -webkit-overflow-scrolling:touch; }
            .form-modal h3 { font-size:1.1rem; }
            .form-modal .form-sub { font-size:0.68rem; margin-bottom:1.2rem; }
            .form-modal .form-group { margin-bottom:0.9rem; }
            .form-modal label { font-size:0.62rem; letter-spacing:1px; }
            .form-modal input, .form-modal textarea, .form-modal select {
                padding:0.6rem 0.8rem; font-size:0.78rem;
            }
            .form-modal .form-submit { padding:0.7rem; font-size:0.78rem; }
        }
        @media (max-width:400px) {
            .hero h1 { font-size:1.6rem; }
            .hero p.subtitle { font-size:0.72rem; }
            .hero-stats { gap:0.8rem; }
            .hero-stat .num { font-size:1.3rem; }
            .section-title, .glitch-subtle, .glitch { font-size:1.3rem !important; }
            .glitch-tag { font-size:0.55rem; }
            .hover-hint .visit-btn { padding:0.4rem 0.85rem; font-size:0.7rem; }
        }
    </style>
</head>
<body>

<div class="cursor-dot" id="cursorDot"></div>
<div class="cursor-ring" id="cursorRing"></div>

<!-- Futuristic background ambience overlays -->
<div class="bg-vignette"></div>
<div class="bg-noise"></div>
<div class="bg-slow-scan"></div>
<div class="bg-datastream ds1"></div>
<div class="bg-datastream ds2"></div>
<div class="bg-datastream ds3"></div>
<div class="bg-datastream ds4"></div>
<div class="bg-datastream ds5"></div>
<div class="bg-datastream ds6"></div>
<div class="bg-hud-axis axis-h"></div>
<div class="bg-hud-axis axis-v"></div>

<canvas id="codeRain"></canvas>

<!-- Floating orbs -->
<div class="orb orb-1"></div>
<div class="orb orb-2"></div>
<div class="orb orb-3"></div>

<div class="grid-bg" id="parallaxGrid"></div>
<div class="scan-line"></div>

<div class="perspective-wrap">

<nav>
    <div class="nav-inner">
        <button class="hamburger" id="hamburgerBtn" aria-label="Menu"><span></span><span></span><span></span></button>
        <div class="nav-logo"><img src="favicon.png" alt="KMM"></div>
        <ul class="nav-links" id="navMenu">
            <li><a href="#about">About</a></li><li><a href="#services">Services</a></li><li><a href="#expertise">Expertise</a></li><li><a href="#projects">Projects</a></li><li><a href="#process">Process</a></li><li><a href="#contact">Contact</a></li>
        </ul>
        <div class="nav-cta-wrap" id="desktopCta"><button class="nav-cta" onclick="openFormModal()" style="font-family:inherit;font-size:inherit;">[ Connect ]</button></div>
    </div>
</nav>

<section class="hero" id="home">
    <div class="hero-content">
        <h1 class="reveal">Hi, I'm <span class="name">Kyle Mheler Mungcal</span><span class="gold-dot">.</span></h1>
        <p class="subtitle reveal" id="typingText"><span class="cursor"></span></p>
        <div class="hero-stats reveal">
            <div class="hero-stat"><div class="num">5+</div><div class="label">Years Exp</div></div>
            <div class="hero-stat"><div class="num">30+</div><div class="label">Projects</div></div>
            <div class="hero-stat"><div class="num">334</div><div class="label">Network</div></div>
        </div>
        <div class="hero-buttons reveal">
            <a href="#projects" class="btn btn-primary">▶ View Projects</a>
            <button class="btn btn-outline" onclick="openFormModal()" style="font-family:inherit;font-size:inherit;">◇ Get In Touch</button>
        </div>
    </div>
</section>

<section id="about">
    <h2 class="glitch-subtle reveal" data-text="<About Me/>">
        &lt;<span class="green">About</span> <span class="gold">Me</span>/&gt;
        <span class="r" aria-hidden="true">&lt;<span class="green">About</span> <span class="gold">Me</span>/&gt;</span>
        <span class="g" aria-hidden="true">&lt;<span class="green">About</span> <span class="gold">Me</span>/&gt;</span>
        <span class="b" aria-hidden="true">&lt;<span class="green">About</span> <span class="gold">Me</span>/&gt;</span>
    </h2>
    <p class="section-subtitle reveal">// Passionate about crafting exceptional digital experiences</p>
    <div class="about-grid">
        <div class="about-card reveal-left">
            <div class="corner-deco corner-tl"></div><div class="corner-deco corner-br"></div>
            <h3>&gt; whoami</h3>
            <p>I'm a <strong>Full Stack Web Developer</strong> based in Manila, Philippines with over <strong style="color:var(--accent)">5 years</strong> of experience turning ideas into interactive, user‑friendly websites. I craft responsive designs that perform seamlessly across all devices.</p>
            <p>I solve problems with creative digital solutions and thrive on delivering websites that leave a lasting impression — whether it's a complete build, redesign, or optimization.</p>
        </div>
        <div class="about-highlights reveal-right reveal-stagger">
            <div class="highlight-item"><div class="icon"><svg width="40" height="40" viewBox="0 0 40 40"><rect x="5" y="5" width="30" height="30" rx="3" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="10" y1="14" x2="30" y2="14" stroke="currentColor" stroke-width="1"/><line x1="10" y1="19" x2="24" y2="19" stroke="currentColor" stroke-width="1"/><line x1="10" y1="24" x2="20" y2="24" stroke="currentColor" stroke-width="1"/><circle cx="33" cy="8" r="2.5" fill="currentColor"/><polygon points="30,32 35,36 28,38" fill="none" stroke="currentColor" stroke-width="1.5"/></svg></div><h4>UI/UX Design</h4><p>Intuitive, beautiful interfaces</p></div>
            <div class="highlight-item"><div class="icon"><svg width="40" height="40" viewBox="0 0 40 40"><polygon points="20,5 35,14 35,30 20,38 5,30 5,14" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="20" y1="5" x2="20" y2="38" stroke="currentColor" stroke-width="1"/><line x1="5" y1="14" x2="35" y2="14" stroke="currentColor" stroke-width="1"/><polygon points="18,20 12,26 18,32" fill="none" stroke="currentColor" stroke-width="1.5"/><polygon points="22,20 28,26 22,32" fill="none" stroke="currentColor" stroke-width="1.5"/></svg></div><h4>Web Development</h4><p>Modern, responsive websites</p></div>
            <div class="highlight-item"><div class="icon"><svg width="40" height="40" viewBox="0 0 40 40"><circle cx="20" cy="16" r="10" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="27" y1="23" x2="33" y2="29" stroke="currentColor" stroke-width="2"/><circle cx="20" cy="16" r="4" fill="none" stroke="currentColor" stroke-width="1"/><line x1="20" y1="6" x2="20" y2="10" stroke="currentColor" stroke-width="1.5"/><line x1="20" y1="22" x2="20" y2="26" stroke="currentColor" stroke-width="1.5"/><line x1="10" y1="16" x2="14" y2="16" stroke="currentColor" stroke-width="1.5"/><line x1="26" y1="16" x2="30" y2="16" stroke="currentColor" stroke-width="1.5"/></svg></div><h4>SEO</h4><p>Search engine optimization</p></div>
            <div class="highlight-item"><div class="icon"><svg width="40" height="40" viewBox="0 0 40 40"><rect x="8" y="8" width="24" height="24" rx="4" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="15" y1="15" x2="25" y2="25" stroke="currentColor" stroke-width="1.2"/><circle cx="20" cy="20" r="2" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/><circle cx="28" cy="28" r="1.5" fill="currentColor"/></svg></div><h4>Branding</h4><p>Identity & procurement</p></div>
        </div>
    </div>
</section>

<section id="services">
    <h2 class="glitch-subtle reveal" data-text="<Services/>">
        &lt;<span class="green">Services</span>/&gt;
        <span class="r" aria-hidden="true">&lt;<span class="green">Services</span>/&gt;</span>
        <span class="g" aria-hidden="true">&lt;<span class="green">Services</span>/&gt;</span>
        <span class="b" aria-hidden="true">&lt;<span class="green">Services</span>/&gt;</span>
    </h2>
    <p class="section-subtitle reveal">// Comprehensive solutions to bring your vision to life</p>
    <div class="services-grid reveal-stagger">
        <div class="service-card"><div class="service-icon"><svg width="40" height="40" viewBox="0 0 40 40"><rect x="4" y="4" width="32" height="32" rx="3" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="18" cy="18" r="6" fill="none" stroke="currentColor" stroke-width="1.2"/><path d="M22,22 l8,8" stroke="currentColor" stroke-width="1.5"/><circle cx="28" cy="12" r="2" fill="currentColor"/><line x1="4" y1="12" x2="8" y2="12" stroke="currentColor" stroke-width="1"/><line x1="32" y1="12" x2="36" y2="12" stroke="currentColor" stroke-width="1"/></svg></div><h4>UI/UX Design</h4><p>Wireframes, mockups, and interactive prototypes for optimal user experience.</p></div>
        <div class="service-card"><div class="service-icon"><svg width="40" height="40" viewBox="0 0 40 40"><polygon points="10,6 2,20 10,34" fill="none" stroke="currentColor" stroke-width="1.5"/><polygon points="30,6 38,20 30,34" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="1.5" fill="currentColor"/><line x1="14" y1="20" x2="16" y2="20" stroke="currentColor" stroke-width="2"/><line x1="24" y1="20" x2="26" y2="20" stroke="currentColor" stroke-width="2"/></svg></div><h4>Web Development</h4><p>High-performance responsive websites built with modern technologies.</p></div>
        <div class="service-card"><div class="service-icon"><svg width="40" height="40" viewBox="0 0 40 40"><circle cx="18" cy="20" r="14" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="36" cy="6" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M26,14 L32,9" stroke="currentColor" stroke-width="1.2"/><line x1="18" y1="8" x2="18" y2="14" stroke="currentColor" stroke-width="1.2"/><polygon points="18,6 15,12 21,12" fill="currentColor"/><circle cx="18" cy="20" r="6" fill="none" stroke="currentColor" stroke-width="1"/></svg></div><h4>SEO Optimization</h4><p>Strategic search optimization to boost your online visibility.</p></div>
        <div class="service-card"><div class="service-icon"><svg width="40" height="40" viewBox="0 0 40 40"><polygon points="20,4 36,12 36,28 20,36 4,28 4,12" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="20" r="8" fill="none" stroke="currentColor" stroke-width="1.2"/><circle cx="20" cy="20" r="3" fill="currentColor"/><line x1="20" y1="4" x2="20" y2="12" stroke="currentColor" stroke-width="1"/><line x1="20" y1="28" x2="20" y2="36" stroke="currentColor" stroke-width="1"/></svg></div><h4>Branding</h4><p>Compelling brand identity that resonates with your audience.</p></div>
    </div>
</section>

<section id="expertise">
    <h2 class="glitch-subtle reveal" data-text="<Expertise/>">
        &lt;<span class="green">Expertise</span>/&gt;
        <span class="r" aria-hidden="true">&lt;<span class="green">Expertise</span>/&gt;</span>
        <span class="g" aria-hidden="true">&lt;<span class="green">Expertise</span>/&gt;</span>
        <span class="b" aria-hidden="true">&lt;<span class="green">Expertise</span>/&gt;</span>
    </h2>
    <p class="section-subtitle reveal">// Specialized platforms and custom solutions</p>
    <div class="expertise-grid reveal-stagger">
        <div class="expertise-card">
            <div class="expertise-icon"><svg width="48" height="48" viewBox="0 0 48 48"><rect x="4" y="6" width="40" height="36" rx="4" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="4" y1="16" x2="44" y2="16" stroke="currentColor" stroke-width="1.2"/><circle cx="24" cy="6" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M18,30 l3,-5 h6 l3,5" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="20" cy="26" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="28" cy="26" r="2" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="24" y1="20" x2="24" y2="24" stroke="currentColor" stroke-width="1.5"/></svg></div>
            <h4>Shopify Development</h4>
            <p>Custom Shopify stores, theme customization, app integration, and conversion-optimized e-commerce solutions that drive sales.</p>
            <div class="expertise-tags">
                <span>Shopify</span><span>Liquid</span><span>Shopify Plus</span><span>E-commerce</span>
            </div>
        </div>
        <div class="expertise-card">
            <div class="expertise-icon"><svg width="48" height="48" viewBox="0 0 48 48"><circle cx="24" cy="24" r="18" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M12,30 Q12,16 24,12 Q36,16 36,30 Q24,20 12,30" fill="none" stroke="currentColor" stroke-width="1.2"/><circle cx="20" cy="18" r="2" fill="currentColor"/><path d="M24,12 Q28,20 24,28 Q20,20 24,12" fill="none" stroke="currentColor" stroke-width="1"/><path d="M16,26 Q24,30 32,26" fill="none" stroke="currentColor" stroke-width="1"/></svg></div>
            <h4>WordPress Development</h4>
            <p>Custom themes, plugin development, WooCommerce stores, and high-performance WordPress sites tailored to your brand.</p>
            <div class="expertise-tags">
                <span>WordPress</span><span>WooCommerce</span><span>Elementor</span><span>PHP</span>
            </div>
        </div>
        <div class="expertise-card">
            <div class="expertise-icon"><svg width="48" height="48" viewBox="0 0 48 48"><rect x="6" y="6" width="36" height="36" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><line x1="6" y1="16" x2="48" y2="16" stroke="currentColor" stroke-width="1"/><circle cx="12" cy="11" r="2" fill="currentColor"/><circle cx="19" cy="11" r="2" fill="currentColor"/><circle cx="26" cy="11" r="2" fill="currentColor"/><path d="M16,24 l3,4 l-3,4" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M32,24 l-3,4 l3,4" fill="none" stroke="currentColor" stroke-width="1.8"/><path d="M24,20 l-2,12 l2,-1" fill="none" stroke="currentColor" stroke-width="1.2"/></svg></div>
            <h4>Custom Development</h4>
            <p>Full-stack web applications, custom CMS, API integrations, and bespoke solutions built with modern technologies.</p>
            <div class="expertise-tags">
                <span>HTML/CSS</span><span>JavaScript</span><span>Python</span><span>React</span>
            </div>
        </div>
    </div>
</section>

<section id="projects">
    <div class="section-title-wrap reveal">
        <div class="glitch-tag">// PROJECTS.DB :: v3.0.7</div>
        <h2 class="glitch" data-text="<Recent Projects/>">
            &lt;<span class="green">Recent</span> <span class="gold">Projects</span>/&gt;
            <span class="r" aria-hidden="true">&lt;<span class="green">Recent</span> <span class="gold">Projects</span>/&gt;</span>
            <span class="g" aria-hidden="true">&lt;<span class="green">Recent</span> <span class="gold">Projects</span>/&gt;</span>
            <span class="b" aria-hidden="true">&lt;<span class="green">Recent</span> <span class="gold">Projects</span>/&gt;</span>
            <span class="tear t1"></span><span class="tear t2"></span><span class="tear t3"></span>
        </h2>
    </div>
    <p class="section-subtitle reveal">// Click any card to visit the live website</p>
    <div class="projects-grid reveal-stagger">

        <a class="project-card" href="https://northwestaerosolutions.com" target="_blank" rel="noopener noreferrer">
            <div class="project-image" style="background-image:url('project-thumbs/northwest-aero.jpg');">
                <div class="hover-hint">
                    <span class="visit-btn">◈ VISIT SITE ◈</span>
                    <span class="visit-arrow">→  OPEN IN NEW TAB  ←</span>
                </div>
            </div>
            <div class="project-info"><h4>Northwest Aero Solutions</h4><div class="domain">northwestaerosolutions.com</div><p>A trusted ally in defense & security — dedicated to providing reliable support and advanced technology solutions for safety and peace.</p></div>
        </a>

