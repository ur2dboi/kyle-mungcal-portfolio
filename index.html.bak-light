        <h2 class="glitch-subtle" data-text="<Let's Build Something Amazing/>">
            &lt;<span class="green">Let's Build</span> Something <span class="gold">Amazing</span>/&gt;
            <span class="r" aria-hidden="true">&lt;<span class="green">Let's Build</span> Something <span class="gold">Amazing</span>/&gt;</span>
            <span class="g" aria-hidden="true">&lt;<span class="green">Let's Build</span> Something <span class="gold">Amazing</span>/&gt;</span>
            <span class="b" aria-hidden="true">&lt;<span class="green">Let's Build</span> Something <span class="gold">Amazing</span>/&gt;</span>
