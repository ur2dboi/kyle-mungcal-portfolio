<!-- CONTACT FORM MODAL -->
<div class="form-modal-overlay" id="formModal" onclick="if(event.target===this)closeFormModal()">
    <div class="form-modal">
        <button class="form-close" onclick="closeFormModal()" title="Close (Esc)">✕</button>

        <div id="formContent">
            <h3>&gt; Start Your Project</h3>
            <p class="form-sub">Fill out the form and I'll get back to you within 24 hours</p>

            <form id="contactForm" onsubmit="return handleFormSubmit(event)">
                <div class="form-group">
                    <label>Name *</label>
                    <input type="text" name="name" placeholder="Your full name" required>
                </div>
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" name="email" placeholder="your@email.com" required>
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" name="phone" placeholder="+63 9XX XXX XXXX">
                </div>
                <div class="form-group">
                    <label>Services Needed</label>
                    <select name="service">
                        <option value="">Select a service...</option>
                        <option value="Web Development">Web Development</option>
                        <option value="UI/UX Design">UI/UX Design</option>
                        <option value="SEO Optimization">SEO Optimization</option>
                        <option value="WordPress Design">WordPress Design</option>
                        <option value="E-commerce">E-commerce</option>
                        <option value="Branding">Branding</option>
                        <option value="Other">Other / Multiple</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Project Details</label>
                    <textarea name="message" placeholder="Tell me about your project..."></textarea>
                </div>
                <button type="submit" class="form-submit" id="formSubmitBtn">▶ Send Message</button>
            </form>
        </div>

        <div class="form-success" id="formSuccess">
            <div class="success-icon"><svg width="48" height="48" viewBox="0 0 48 48"><circle cx="24" cy="24" r="22" fill="none" stroke="#00ff88" stroke-width="1.5"/><polyline points="14,24 20,30 34,18" fill="none" stroke="#00ff88" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="24" cy="24" r="4" fill="none" stroke="#00ff88" stroke-width="1"/></svg></div>
            <h3>&lt; Message Sent /&gt;</h3>
            <p>Thanks for reaching out! I'll get back to you within 24 hours.</p>
        </div>
    </div>
</div>


<script>
(function () {
    'use strict';

    /* ── Typing animation (hero subtitle) ── */
    const typingEl = document.getElementById('typingText');
    const phrases = [
        'Full Stack Web Developer',
        'Shopify & WordPress Expert',
        'UI/UX Designer  •  SEO Specialist',
        'Turning ideas into interactive websites.'
    ];
    let phraseIdx = 0, charIdx = 0, deleting = false;
    function typeLoop() {
        if (!typingEl) return;
        const cur = phrases[phraseIdx];
        const cursor = '<span class="cursor"></span>';
        if (!deleting) {
            charIdx++;
            typingEl.innerHTML = cur.substring(0, charIdx) + cursor;
            if (charIdx === cur.length) { deleting = true; setTimeout(typeLoop, 1600); return; }
        } else {
            charIdx--;
            typingEl.innerHTML = cur.substring(0, charIdx) + cursor;
            if (charIdx === 0) { deleting = false; phraseIdx = (phraseIdx + 1) % phrases.length; }
        }
        setTimeout(typeLoop, deleting ? 35 : 70);
    }
    setTimeout(typeLoop, 500);

    /* ── Scroll Reveal (IntersectionObserver) ── */
    const revealSel = '.reveal, .reveal-left, .reveal-right, .reveal-scale, .reveal-stagger';
    const io = new IntersectionObserver((entries) => {
        entries.forEach(e => {
            if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
        });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll(revealSel).forEach(el => io.observe(el));

    /* ── Custom cursor (desktop only) ── */
    const dot = document.getElementById('cursorDot');
    const ring = document.getElementById('cursorRing');
    const isFine = window.matchMedia('(pointer: fine)').matches;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (isFine && dot && ring && !reducedMotion) {
        let mx = window.innerWidth / 2, my = window.innerHeight / 2;
        let dx = mx, dy = my;
        let rafId = null;
        const onMove = (e) => { mx = e.clientX; my = e.clientY; };
        document.addEventListener('mousemove', onMove, { passive: true });
        function animCursor() {
            dx += (mx - dx) * 0.18; dy += (my - dy) * 0.18;
            // dot is 8px → center at 4; ring is 36px → center at 18 (hover size 48 → center 24 handled by CSS transition on width/height from top-left)
            dot.style.transform = `translate3d(${mx - 4}px,${my - 4}px,0)`;
            ring.style.transform = `translate3d(${dx - 18}px,${dy - 18}px,0)`;
            rafId = requestAnimationFrame(animCursor);
        }
        animCursor();
        const hoverables = 'a, button, .project-card, .service-card, .expertise-card, .process-step, .highlight-item, .benefit-item, input, textarea, select, .nav-cta, .scroll-top-btn, .visit-btn';
        document.querySelectorAll(hoverables).forEach(el => {
            el.addEventListener('mouseenter', () => { dot.classList.add('hovering'); ring.classList.add('hovering'); });
            el.addEventListener('mouseleave', () => { dot.classList.remove('hovering'); ring.classList.remove('hovering'); });
        });
        // Ripple on click
        document.addEventListener('mousedown', (e) => {
            const r = document.createElement('div');
            r.style.cssText = `position:fixed;left:${e.clientX}px;top:${e.clientY}px;width:0;height:0;border:2px solid rgba(0,255,136,0.6);border-radius:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:99997;animation:rippleOut 0.6s ease-out forwards;`;
            document.body.appendChild(r);
            setTimeout(() => r.remove(), 650);
        });
    }

    /* ── Hamburger menu ── */
    const hamburger = document.getElementById('hamburgerBtn');
    const navMenu = document.getElementById('navMenu');
    if (hamburger && navMenu) {
        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('open');
            navMenu.classList.toggle('open');
        });
        navMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
            hamburger.classList.remove('open'); navMenu.classList.remove('open');
        }));
    }

    /* ── Form modal (mailto fallback, instant success) ── */
    const formModal = document.getElementById('formModal');
    const contactForm = document.getElementById('contactForm');
    const formContent = document.getElementById('formContent');
    const formSuccess = document.getElementById('formSuccess');
    const formSubmitBtn = document.getElementById('formSubmitBtn');
    window.openFormModal = function () {
        if (!formModal) return;
        formModal.classList.add('active');
        document.body.classList.add('no-scroll');
        setTimeout(() => formModal.querySelector('input,textarea,select,button')?.focus(), 200);
    };
    window.closeFormModal = function () {
        if (!formModal) return;
        formModal.classList.remove('active');
        document.body.classList.remove('no-scroll');
    };
    window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeFormModal(); });
    window.handleFormSubmit = function (e) {
        e.preventDefault();
        if (!contactForm) return false;
        const fd = new FormData(contactForm);
        const name = (fd.get('name') || '').trim();
        const email = (fd.get('email') || '').trim();
        const phone = (fd.get('phone') || '').trim();
        const service = (fd.get('service') || '').trim();
        const message = (fd.get('message') || '').trim();
        const subject = encodeURIComponent(`New Project Inquiry${service ? ' - ' + service : ''}${name ? ' from ' + name : ''}`);
        const body = encodeURIComponent(
            `Name: ${name}\nEmail: ${email}\nPhone: ${phone}\nService: ${service}\n\nMessage:\n${message}`
        );
        if (formSubmitBtn) { formSubmitBtn.disabled = true; formSubmitBtn.textContent = 'Sending…'; }
        window.location.href = `mailto:kylemheler02@gmail.com?subject=${subject}&body=${body}`;
        setTimeout(() => {
            if (formContent) formContent.style.display = 'none';
            if (formSuccess) formSuccess.style.display = 'block';
            setTimeout(() => {
                closeFormModal();
                contactForm.reset();
                setTimeout(() => {
                    if (formContent) formContent.style.display = 'block';
                    if (formSuccess) formSuccess.style.display = 'none';
                    if (formSubmitBtn) { formSubmitBtn.disabled = false; formSubmitBtn.textContent = '▶ Send Message'; }
                }, 400);
            }, 2200);
        }, 400);
        return false;
    };

    /* ── Scroll-to-top button + Parallax grid (single rAF-throttled scroll handler) ── */
    const scrollTopBtn = document.getElementById('scrollTopBtn');
    const grid = document.getElementById('parallaxGrid');
    let scrollTicking = false;
    function onScroll() {
        if (scrollTicking) return;
        scrollTicking = true;
        requestAnimationFrame(() => {
            const y = window.scrollY;
            if (scrollTopBtn) {
                if (y > 500) scrollTopBtn.classList.add('visible');
                else scrollTopBtn.classList.remove('visible');
            }
            if (grid) grid.style.transform = `translate3d(0,${y * 0.08}px,0) scale(1)`;
            scrollTicking = false;
        });
    }
    if (scrollTopBtn || grid) window.addEventListener('scroll', onScroll, { passive: true });

    /* ── 3D tilt on cards (desktop only, rAF-throttled, gentle) ── */
    const tiltSel = '.service-card, .expertise-card, .process-step, .highlight-item, .about-card';
    if (isFine && !reducedMotion) {
        document.querySelectorAll(tiltSel).forEach(card => {
            let raf = null;
            card.addEventListener('mousemove', (e) => {
                if (raf) return;
                raf = requestAnimationFrame(() => {
                    const r = card.getBoundingClientRect();
                    const x = (e.clientX - r.left) / r.width - 0.5;
                    const y = (e.clientY - r.top) / r.height - 0.5;
                    card.style.transform = `translate3d(0,-6px,0) perspective(900px) rotateY(${x * 3}deg) rotateX(${-y * 3}deg)`;
                    raf = null;
                });
            }, { passive: true });
            card.addEventListener('mouseleave', () => {
                if (raf) { cancelAnimationFrame(raf); raf = null; }
                card.style.transform = '';
            });
        });
    }

    /* Pause heavy CSS animations when tab is hidden */
    document.addEventListener('visibilitychange', () => {
        document.body.classList.toggle('tab-hidden', document.hidden);
    });

    /* ── Matrix code rain (throttled for smoothness) ── */
    const canvas = document.getElementById('codeRain');
    if (canvas && isFine && !reducedMotion) {
        const ctx = canvas.getContext('2d', { alpha: true });
        let W, H, cols, drops, lastDraw = 0;
        const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン<>/{}[]=+*&^%$#@!';
        const fontSize = 16;
        const FRAME_MS = 55; // ~18 fps — smooth-looking but cheap
        let rainRunning = true;
        function resize() {
            W = canvas.width = window.innerWidth;
            H = canvas.height = window.innerHeight;
            cols = Math.floor(W / fontSize);
            drops = new Array(cols).fill(0).map(() => Math.random() * -80);
        }
        resize();
        window.addEventListener('resize', () => {
            if (!resize._t) { resize._t = setTimeout(() => { resize(); resize._t = null; }, 150); }
        });
        function draw(ts) {
            if (!rainRunning) return;
            requestAnimationFrame(draw);
            if (ts - lastDraw < FRAME_MS) return;
            lastDraw = ts;
            ctx.fillStyle = 'rgba(0,0,0,0.10)';
            ctx.fillRect(0, 0, W, H);
            ctx.fillStyle = 'rgba(0,255,136,0.5)';
            ctx.font = fontSize + "px 'Courier New', monospace";
            // Only draw every other column to reduce overdraw
            for (let i = 0; i < cols; i += 2) {
                const ch = chars[(Math.random() * chars.length) | 0];
                ctx.fillText(ch, i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > H && Math.random() > 0.97) drops[i] = 0;
                drops[i]++;
            }
        }
        requestAnimationFrame(draw);
        // Pause when tab hidden
        document.addEventListener('visibilitychange', () => {
            rainRunning = !document.hidden;
            if (rainRunning) requestAnimationFrame(draw);
        });
    } else if (canvas) {
        // On mobile / reduced motion: show static faint green tint instead
        canvas.style.display = 'none';
    }

    /* ── Smooth scroll offset for fixed nav ── */
    document.querySelectorAll('a[href^="#"]').forEach(a => {
        a.addEventListener('click', (e) => {
            const id = a.getAttribute('href');
            if (id.length <= 1) return;
            const target = document.querySelector(id);
            if (!target) return;
            e.preventDefault();
            const top = target.getBoundingClientRect().top + window.scrollY - 72;
            window.scrollTo({ top, behavior: 'smooth' });
        });
    });

})();
</script>
</body>
</html>
