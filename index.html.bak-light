<section id="process">
    <h2 class="glitch-subtle reveal" data-text="<Development Process/>">
        &lt;<span class="green">Development</span> <span class="gold">Process</span>/&gt;
        <span class="r" aria-hidden="true">&lt;<span class="green">Development</span> <span class="gold">Process</span>/&gt;</span>
        <span class="g" aria-hidden="true">&lt;<span class="green">Development</span> <span class="gold">Process</span>/&gt;</span>
